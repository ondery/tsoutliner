{
  "name": "tsoutliner",
  "author": {
    "name": "Öndery",
    "url": "https://github.com/ondery"
  },
  "displayName": "TS Outliner",
  "description": "Enhanced outline view for TypeScript, JavaScript, JSX, TSX, Markdown, and JSON with modern Lucide icons, fonts, and sorting.",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ondery/tsoutliner.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:markdown",
    "onLanguage:json",
    "onLanguage:jsonc",
    "onView:tsOutlineEnhancer.webview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tsOutlineEnhancer.refresh",
        "title": "Refresh Outline",
        "category": "TS Outliner",
        "icon": "$(refresh)"
      },
      {
        "command": "tsOutlineEnhancer.openEmojiSettings",
        "title": "Open Emoji Settings",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.openIconSettings",
        "title": "Open Icon Settings",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.openModernIconSettings",
        "title": "Open Modern Icon Settings",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.openToolbarIconSettings",
        "title": "Open Toolbar Icon Settings",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.openFontSettings",
        "title": "Open Font Settings",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.openIconAppearanceSettings",
        "title": "Open Icon Appearance Settings",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.openAllSettings",
        "title": "Open Settings",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.selectFont",
        "title": "Select Font Family",
        "category": "TS Outliner",
        "icon": "$(symbol-text)"
      },
      {
        "command": "tsOutlineEnhancer.sortByPosition",
        "title": "Sort By: Position",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.sortByName",
        "title": "Sort By: Name",
        "category": "TS Outliner"
      },
      {
        "command": "tsOutlineEnhancer.sortByCategory",
        "title": "Sort By: Category",
        "category": "TS Outliner"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ts-outliner",
          "title": "TS Outliner",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "ts-outliner": [
        {
          "type": "webview",
          "id": "tsOutlineEnhancer.webview",
          "name": "Outline",
          "contextualTitle": "TS Outliner",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "configuration": {
      "title": "TS Outliner",
      "properties": {
        "tsOutlineEnhancer.iconType": {
          "type": "string",
          "enum": [
            "modern",
            "emoji",
            "fontawesome",
            "none"
          ],
          "default": "modern",
          "description": "Icon style for outline symbols, visibility, and modifiers",
          "enumDescriptions": [
            "Modern Lucide line icons (theme-aware, recommended)",
            "Emoji icons (🌐, 🔒, etc.)",
            "Font Awesome icons",
            "Don't show any icons"
          ]
        },
        "tsOutlineEnhancer.modernIconSettings": {
          "type": "object",
          "default": {
            "public": "lucide:globe",
            "private": "lucide:lock",
            "protected": "lucide:shield",
            "static": "lucide:pin",
            "readonly": "lucide:eye",
            "abstract": "lucide:shapes",
            "async": "lucide:zap",
            "export": "lucide:share-2",
            "default": "lucide:star",
            "constructor": "lucide:hammer",
            "property": "lucide:tag",
            "method": "lucide:cog",
            "function": "lucide:square-function",
            "getter": "lucide:arrow-up-from-line",
            "setter": "lucide:arrow-down-to-line",
            "class": "lucide:box",
            "interface": "lucide:component",
            "heading": "lucide:heading",
            "variable": "lucide:variable",
            "constant": "lucide:diamond",
            "enum": "lucide:list",
            "enumMember": "lucide:circle",
            "module": "lucide:folder",
            "namespace": "lucide:folder-open",
            "typeAlias": "lucide:type",
            "file": "lucide:file-text",
            "object": "lucide:braces",
            "array": "lucide:brackets",
            "key": "lucide:key",
            "event": "lucide:radio",
            "operator": "lucide:plus",
            "typeParameter": "lucide:baseline"
          },
          "properties": {
            "public": {
              "type": "string",
              "default": "lucide:globe",
              "description": "Iconify ID for public (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:globe",
                "lucide:radio",
                "lucide:eye"
              ]
            },
            "private": {
              "type": "string",
              "default": "lucide:lock",
              "description": "Iconify ID for private (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:lock",
                "lucide:key",
                "lucide:shield"
              ]
            },
            "protected": {
              "type": "string",
              "default": "lucide:shield",
              "description": "Iconify ID for protected (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:shield",
                "lucide:lock",
                "lucide:pin"
              ]
            },
            "static": {
              "type": "string",
              "default": "lucide:pin",
              "description": "Iconify ID for static (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:pin",
                "lucide:map-pin",
                "lucide:diamond"
              ]
            },
            "readonly": {
              "type": "string",
              "default": "lucide:eye",
              "description": "Iconify ID for readonly (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:eye",
                "lucide:book-open",
                "lucide:lock"
              ]
            },
            "abstract": {
              "type": "string",
              "default": "lucide:shapes",
              "description": "Iconify ID for abstract (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:shapes",
                "lucide:ghost",
                "lucide:sparkles"
              ]
            },
            "async": {
              "type": "string",
              "default": "lucide:zap",
              "description": "Iconify ID for async (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:zap",
                "lucide:infinity",
                "lucide:refresh-cw"
              ]
            },
            "export": {
              "type": "string",
              "default": "lucide:share-2",
              "description": "Iconify ID for export (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:share-2",
                "lucide:upload",
                "lucide:arrow-up-from-line"
              ]
            },
            "default": {
              "type": "string",
              "default": "lucide:star",
              "description": "Iconify ID for default (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:star",
                "lucide:sparkles",
                "lucide:circle-dot"
              ]
            },
            "constructor": {
              "type": "string",
              "default": "lucide:hammer",
              "description": "Iconify ID for constructor (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:hammer",
                "lucide:wrench",
                "lucide:cog"
              ]
            },
            "property": {
              "type": "string",
              "default": "lucide:tag",
              "description": "Iconify ID for property (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:tag",
                "lucide:hash",
                "lucide:square"
              ]
            },
            "method": {
              "type": "string",
              "default": "lucide:cog",
              "description": "Iconify ID for method (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:cog",
                "lucide:wrench",
                "lucide:zap"
              ]
            },
            "function": {
              "type": "string",
              "default": "lucide:square-function",
              "description": "Iconify ID for function (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:square-function",
                "lucide:variable",
                "lucide:braces"
              ]
            },
            "getter": {
              "type": "string",
              "default": "lucide:arrow-up-from-line",
              "description": "Iconify ID for getter (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:arrow-up-from-line",
                "lucide:download",
                "lucide:eye"
              ]
            },
            "setter": {
              "type": "string",
              "default": "lucide:arrow-down-to-line",
              "description": "Iconify ID for setter (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:arrow-down-to-line",
                "lucide:upload",
                "lucide:tag"
              ]
            },
            "class": {
              "type": "string",
              "default": "lucide:box",
              "description": "Iconify ID for class (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:box",
                "lucide:component",
                "lucide:layers"
              ]
            },
            "interface": {
              "type": "string",
              "default": "lucide:component",
              "description": "Iconify ID for interface (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:component",
                "lucide:list-tree",
                "lucide:braces"
              ]
            },
            "heading": {
              "type": "string",
              "default": "lucide:heading",
              "description": "Iconify ID for heading (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:heading",
                "lucide:hash",
                "lucide:type"
              ]
            },
            "variable": {
              "type": "string",
              "default": "lucide:variable",
              "description": "Iconify ID for variable (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:variable",
                "lucide:box",
                "lucide:circle"
              ]
            },
            "constant": {
              "type": "string",
              "default": "lucide:diamond",
              "description": "Iconify ID for constant (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:diamond",
                "lucide:lock",
                "lucide:pin"
              ]
            },
            "enum": {
              "type": "string",
              "default": "lucide:list",
              "description": "Iconify ID for enum (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:list",
                "lucide:list-ordered",
                "lucide:layers"
              ]
            },
            "enumMember": {
              "type": "string",
              "default": "lucide:circle",
              "description": "Iconify ID for enumMember (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:circle",
                "lucide:circle-dot",
                "lucide:square"
              ]
            },
            "module": {
              "type": "string",
              "default": "lucide:folder",
              "description": "Iconify ID for module (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:folder",
                "lucide:box",
                "lucide:layers"
              ]
            },
            "namespace": {
              "type": "string",
              "default": "lucide:folder-open",
              "description": "Iconify ID for namespace (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:folder-open",
                "lucide:layers",
                "lucide:folder"
              ]
            },
            "typeAlias": {
              "type": "string",
              "default": "lucide:type",
              "description": "Iconify ID for typeAlias (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:type",
                "lucide:tag",
                "lucide:baseline"
              ]
            },
            "file": {
              "type": "string",
              "default": "lucide:file-text",
              "description": "Iconify ID for file (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:file-text",
                "lucide:book-open",
                "lucide:text-cursor-input"
              ]
            },
            "object": {
              "type": "string",
              "default": "lucide:braces",
              "description": "Iconify ID for object (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:braces",
                "lucide:box",
                "lucide:shapes"
              ]
            },
            "array": {
              "type": "string",
              "default": "lucide:brackets",
              "description": "Iconify ID for array (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:brackets",
                "lucide:list",
                "lucide:list-ordered"
              ]
            },
            "key": {
              "type": "string",
              "default": "lucide:key",
              "description": "Iconify ID for key (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:key",
                "lucide:hash",
                "lucide:tag"
              ]
            },
            "event": {
              "type": "string",
              "default": "lucide:radio",
              "description": "Iconify ID for event (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:radio",
                "lucide:zap",
                "lucide:sparkles"
              ]
            },
            "operator": {
              "type": "string",
              "default": "lucide:plus",
              "description": "Iconify ID for operator (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:plus",
                "lucide:hash",
                "lucide:baseline"
              ]
            },
            "typeParameter": {
              "type": "string",
              "default": "lucide:baseline",
              "description": "Iconify ID for typeParameter (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:baseline",
                "lucide:type",
                "lucide:a-large-small"
              ]
            }
          },
          "additionalProperties": true,
          "description": "Modern Lucide icon IDs for outline symbols (Iconify format: lucide:name). Pick any icon from the bundled catalog."
        },
        "tsOutlineEnhancer.toolbarIconSettings": {
          "type": "object",
          "default": {
            "refresh": "lucide:refresh-cw",
            "collapseAll": "lucide:fold-vertical",
            "font": "lucide:type",
            "sortPosition": "lucide:map-pin",
            "sortName": "lucide:arrow-down-a-z",
            "sortCategory": "lucide:layers",
            "chevron": "lucide:chevron-right"
          },
          "properties": {
            "refresh": {
              "type": "string",
              "default": "lucide:refresh-cw",
              "description": "Iconify ID for refresh button (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:refresh-cw",
                "lucide:infinity",
                "lucide:zap"
              ]
            },
            "collapseAll": {
              "type": "string",
              "default": "lucide:fold-vertical",
              "description": "Iconify ID for collapse-all button (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:fold-vertical",
                "lucide:folder-minus",
                "lucide:list-tree"
              ]
            },
            "font": {
              "type": "string",
              "default": "lucide:type",
              "description": "Iconify ID for font button (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:type",
                "lucide:case-sensitive",
                "lucide:a-large-small"
              ]
            },
            "sortPosition": {
              "type": "string",
              "default": "lucide:map-pin",
              "description": "Iconify ID for sort-by-position button (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:map-pin",
                "lucide:list-ordered",
                "lucide:list-tree"
              ]
            },
            "sortName": {
              "type": "string",
              "default": "lucide:arrow-down-a-z",
              "description": "Iconify ID for sort-by-name button (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:arrow-down-a-z",
                "lucide:a-large-small",
                "lucide:case-sensitive"
              ]
            },
            "sortCategory": {
              "type": "string",
              "default": "lucide:layers",
              "description": "Iconify ID for sort-by-category button (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:layers",
                "lucide:list-tree",
                "lucide:folder"
              ]
            },
            "chevron": {
              "type": "string",
              "default": "lucide:chevron-right",
              "description": "Iconify ID for tree chevron (e.g. lucide:box). Must exist in the bundled catalog.",
              "examples": [
                "lucide:chevron-right",
                "lucide:plus",
                "lucide:circle"
              ]
            }
          },
          "additionalProperties": false,
          "description": "Modern Lucide icon IDs for toolbar actions (Iconify format: lucide:name)."
        },
