          "type": "object",
          "default": {
            "public": "🌐",
            "private": "🔒",
            "protected": "🛡️",
            "static": "📌",
            "readonly": "📖",
            "abstract": "🎭",
            "async": "⚡",
            "export": "📤",
            "default": "🌟",
            "constructor": "🏗️",
            "property": "📝",
            "method": "⚙️",
            "function": "🔧",
